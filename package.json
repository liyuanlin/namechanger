{
  "name": "namechanger",
  "version": "1.0.0",
  "description": "文件批量重命名和内容替换工具 - CLI工具",
  "main": "./dist/index.js",
  "bin": {
    "namechanger": "./dist/index.js"
  },
  "type": "commonjs",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "tscWatch": "tsc -w",
    "start": "tsc && node ./dist/index.js",
    "distWatch": "nodemon ./dist/index.js",
    "dev": "concurrently \"npm run tscWatch\" \"npm run distWatch\"",
    "build": "tsc",
    "prepare": "npm run build"
  },
  "author": "liyuanlin138@gmail.com",
  "license": "ISC",
  "devDependencies": {
    "@tsconfig/node20": "^20.1.5",
    "@types/node": "^22.15.3",
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "chokidar": "^4.0.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "rename",
    "replace",
    "file",
    "cli",
    "tool"
  ],
  "files": [
    "dist/**/*",
    "README.md"
  ]
}